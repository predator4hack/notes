			"text": "🧪  Generics & Wildcards",
			"fontSize": 16,
			"fontFamily": 1,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "oop_02260",
			"originalText": "🧪  Generics & Wildcards",
			"lineHeight": 1.3,
			"fontWeight": 700,
			"autoResize": true,
			"index": "ac",
			"frameId": null,
			"hasTextLink": false,
