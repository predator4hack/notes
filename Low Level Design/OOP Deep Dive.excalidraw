		{
			"type": "text",
			"id": "GNoK4ZIT",
			"x": 121.40008544921875,
			"y": 2304.6,
			"width": 327.1998291015625,
			"height": 20.8,
			"angle": 0,
			"strokeColor": "#f9e2af",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
