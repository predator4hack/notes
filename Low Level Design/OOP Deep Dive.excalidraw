		},
		{
			"type": "text",
			"id": "W8SZstY5",
			"x": 1200,
			"y": 215,
			"width": 646.1513671875,
			"height": 421.20000000000005,
			"angle": 0,
			"strokeColor": "#cdd6f4",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
