			"text": "🌫  IV. Abstraction",
			"fontSize": 15,
			"fontFamily": 1,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "oop_02176",
			"originalText": "🌫  IV. Abstraction",
			"lineHeight": 1.3,
			"fontWeight": 700,
			"autoResize": true,
			"index": "aQ",
			"frameId": null,
			"hasTextLink": false,
			"rawText": ""
		},
		{
			"type": "text",
			"id": "VIudDllH",
			"x": 1728,
			"y": 710,
			"width": 422.8967888360863,
			"height": 543.1687513326715,
			"angle": 0,
			"strokeColor": "#cdd6f4",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"roundness": null,
			"seed": 2193,
			"version": 72,
			"versionNonce": 1284645767,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1775996730238,
			"link": null,
			"locked": false,
			"text": "📺 Analogy: TV remote control.\n   You press \"Volume Up\" → TV gets louder.\n   You don't know (and don't need to know) how the\n   IR signal is encoded, decoded, and processed.\n   WHAT it does is exposed.  HOW is hidden.\n\nFocus on WHAT, hide HOW.\n\nAbstract Class (incomplete blueprint):\n  from abc import ABC, abstractmethod\n\n  class Shape(ABC):\n      @abstractmethod\n      def area(self): pass        # no body!\n      def describe(self):         # concrete method\n          print(f\"Area = {self.area()}\")\n\n  class Circle(Shape):\n      def __init__(self, r): self.r = r\n      def area(self): return 3.14 * self.r**2\n\n  class Rectangle(Shape):\n      def __init__(self, w, h): self.w=w; self.h=h\n      def area(self): return self.w * self.h\n\n  s = Shape()    # TypeError: can't instantiate ✔\n  Circle(5).describe()     # Area = 78.5\n\nInterface (Java) = strict contract:\n  interface Flyable { void fly(); }\n  interface Swimmable { void swim(); }\n  class Duck implements Flyable, Swimmable { ... }\n\n  Abstract vs Interface quick rule:\n  IS-A relationship?   → Abstract class\n  CAN-DO capability?   → Interface\n  (Duck IS-A Bird, but CAN FLY + CAN SWIM)",
			"fontSize": 10.874249275929353,
			"fontFamily": 1,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "📺 Analogy: TV remote control.\n   You press \"Volume Up\" → TV gets louder.\n   You don't know (and don't need to know) how the\n   IR signal is encoded, decoded, and processed.\n   WHAT it does is exposed.  HOW is hidden.\n\nFocus on WHAT, hide HOW.\n\nAbstract Class (incomplete blueprint):\n  from abc import ABC, abstractmethod\n\n  class Shape(ABC):\n      @abstractmethod\n      def area(self): pass        # no body!\n      def describe(self):         # concrete method\n          print(f\"Area = {self.area()}\")\n\n  class Circle(Shape):\n      def __init__(self, r): self.r = r\n      def area(self): return 3.14 * self.r**2\n\n  class Rectangle(Shape):\n      def __init__(self, w, h): self.w=w; self.h=h\n      def area(self): return self.w * self.h\n\n  s = Shape()    # TypeError: can't instantiate ✔\n  Circle(5).describe()     # Area = 78.5\n\nInterface (Java) = strict contract:\n  interface Flyable { void fly(); }\n  interface Swimmable { void swim(); }\n  class Duck implements Flyable, Swimmable { ... }\n\n  Abstract vs Interface quick rule:\n  IS-A relationship?   → Abstract class\n  CAN-DO capability?   → Interface\n  (Duck IS-A Bird, but CAN FLY + CAN SWIM)",
			"lineHeight": 1.35,
			"autoResize": false,
			"index": "aR",
			"frameId": null,
			"hasTextLink": false,
			"rawText": ""
		},
