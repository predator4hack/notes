			"text": "🔧  Constructors",
			"fontSize": 17,
			"fontFamily": 1,
			"textAlign": "center",
			"verticalAlign": "middle",
			"containerId": "oop_02050",
			"originalText": "🔧  Constructors",
			"lineHeight": 1.3,
			"fontWeight": 700,
